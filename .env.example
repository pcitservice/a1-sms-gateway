# =============================================================================
# A1 SMS Gateway — environment template
# Copy to `.env` and fill in. The installer generates secrets automatically.
# =============================================================================

# ---- Top-level identity ----
APP_NAME="A1 SMS Gateway"
APP_ENV=production
APP_URL=https://sms.a1techflow.com
APP_DEBUG=false
APP_KEY=                      # generated: php artisan key:generate
APP_TIMEZONE=Europe/Copenhagen

# ---- Docker Compose project ----
COMPOSE_PROJECT_NAME=a1-sms

# ---- Host port bindings (kept off-default to avoid clashes) ----
# These are the ports the host publishes for each container. Distinct from
# the in-container ports below, which Laravel uses to talk to its peers
# inside the Docker network.
NGINX_HTTP_PORT=8181
NGINX_HTTPS_PORT=8443
WEB_PORT=3100
API_PORT=8100
POSTGRES_HOST_PORT=5532
REDIS_HOST_PORT=6479
RABBITMQ_HOST_PORT=5772
RABBITMQ_UI_HOST_PORT=15772

# ---- Database ----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=a1sms
DB_USERNAME=a1sms
DB_PASSWORD=change-me-strong

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---- Queues / RabbitMQ ----
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=a1sms
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/

# Horizon supervises the redis-backed dispatcher even when SMS queues go to MQ
HORIZON_PREFIX=a1sms-horizon
HORIZON_DOMAIN=

# ---- Mail (SMTP) ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@sms.a1techflow.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Stripe (test keys are fine for non-prod) ----
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=DKK
CASHIER_CURRENCY_LOCALE=da_DK

# ---- Plans (cents) ----
PLAN_STARTER_PRICE_ID=price_starter_99_dkk
PLAN_BUSINESS_PRICE_ID=price_business_299_dkk
PLAN_PRO_PRICE_ID=price_pro_999_dkk

# ---- Trial ----
TRIAL_DAYS=14
TRIAL_SMS_LIMIT=50

# ---- TRB140 / Teltonika gateway defaults ----
# Tenants can override per-gateway in the UI; these are fallbacks for the
# bootstrap gateway used in dev/seed.
TRB140_HOST=192.168.1.1
TRB140_PORT=80
TRB140_PROTOCOL=http
TRB140_USERNAME=admin
TRB140_PASSWORD=
TRB140_SSH_PORT=22
TRB140_SSH_KEY_PATH=/var/lib/a1sms/ssh/trb140

# Optional: when set, an extra MockDriver gateway is registered for dev.
GATEWAY_ENABLE_MOCK=true

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_APP_NAME="A1 SMS Gateway"
NEXT_PUBLIC_API_URL=https://sms.a1techflow.com/api/v1
NEXT_PUBLIC_STRIPE_KEY=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://sms.a1techflow.com

# ---- Security ----
SANCTUM_STATEFUL_DOMAINS=sms.a1techflow.com,localhost:3100
SESSION_DOMAIN=.a1techflow.com
TRUSTED_PROXIES=*
WEBHOOK_SIGNING_SECRET=

# ---- Misc ----
LOG_CHANNEL=stack
LOG_LEVEL=info
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

# Admin bootstrap (used by installer once)
BOOTSTRAP_ADMIN_EMAIL=admin@a1techflow.com
BOOTSTRAP_ADMIN_PASSWORD=
